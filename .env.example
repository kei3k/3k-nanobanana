# ==============================================================================
# 3K Nanobana — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values

# -----------------------------------------------------
# Option 1: AI Studio (API Key)
# -----------------------------------------------------
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_API_KEY_HERE

# -----------------------------------------------------
# Option 2: Vertex AI (Google Cloud)
# -----------------------------------------------------
# Leave GEMINI_API_KEY blank if using Vertex AI.
# Ensure you have run: `gcloud auth application-default login`
VERTEX_PROJECT=arctic-inkwell-491903-f0
VERTEX_LOCATION=us-central1

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Queue Configuration
QUEUE_CONCURRENCY=3
MAX_RETRIES=2

# Image Storage (relative to project root or absolute path)
IMAGE_DIR=./data/images
DB_PATH=./data/nanobana.db

# Default Model: "pro" (Nano Banana Pro) or "flash" (Nano Banana 2)
DEFAULT_MODEL=pro
